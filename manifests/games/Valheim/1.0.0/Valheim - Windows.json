  "gamesScripts": [
    {
      "script": {
        "allGames": false,
        "global": false,
        "scriptEngine": "CSharp",
        "operatingSystem": [
          "Windows",
          "Linux"
        ],
        "scriptEvents": [
          "BeforeServiceCreated",
          "BeforeServiceReinstalled"
        ],
        "name": "Set private password",
        "description": "Set private password",
        "code": "using System;\nusing System.Linq;\n\nvar Globals = new TCAdmin.Scripting.Engines.Addons.CSharpGameGlobals(); // DO NOT MODIFY THIS LINE\n\n// V2: if the PrivatePassword variable is empty, generate a 10-char password from\n// uppercase letters \u002B digits and ThisService.Save(). V3 has no GameService.Save();\n// mutate ThisService.Variables then persist with ServiceManager.UpdateAsync (the\n// ServiceManager global shares the same DbContext scope that loaded ThisService).\nstring current = ThisService.Variables.Parse\u003Cstring\u003E(\u0022PrivatePassword\u0022);\nif (string.IsNullOrEmpty(current))\n{\n    const string alphabet = \u0022ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\u0022;\n    var random = new Random();\n    string password = new string(Enumerable.Range(0, 10)\n        .Select(_ =\u003E alphabet[random.Next(alphabet.Length)])\n        .ToArray());\n\n    ThisService.Variables[\u0022PrivatePassword\u0022] = password;\n    await ServiceManager.UpdateAsync(ThisService, true, ThisCancellationToken);\n}\n",
        "runImpersonated": false,
        "stopService": false,
        "ignoreErrors": false,
        "order": 0,
        "icon": "",
        "scriptInputVariables": [],
        "scriptRoles": [],
        "editor": [],
        "identifier": "86722d1e-cc7c-425a-9e44-5c18ac032ef5"
      }
    },
    {
      "script": {
        "allGames": false,
        "global": false,
        "scriptEngine": "CSharp",
        "operatingSystem": [
          "Windows",
          "Linux"
        ],
        "scriptEvents": [
          "CustomServiceIcon"
        ],
        "name": "Switch update branch",
        "description": "Switch branch to either Staging or Public. Will not take effect before the server has been updated.",
        "code": "using System;\n\nvar Globals = new TCAdmin.Scripting.Engines.Addons.CSharpGameGlobals(); // DO NOT MODIFY THIS LINE\n\n// CustomServiceIcon. The user picks a branch (Public/Staging) from the icon\u0027s input form;\n// V3 already persists that input into ThisService.Variables[\u0022branch\u0022] before this script runs\n// (ServiceController.VerifyInputVariables, saveVariableValues:true on the web hub path).\n// We persist again explicitly so the behaviour matches V2\u0027s ThisService.Save() even if the\n// variable isn\u0027t flagged to auto-save, then tell the user to run the Steam update.\nstring branch = ThisService.Variables.Parse\u003Cstring\u003E(\u0022branch\u0022);\n\nawait ServiceManager.UpdateAsync(ThisService, true, ThisCancellationToken);\n\nScriptConsole.WriteLine($\u0022Branch switched to {branch}. Please run the Steam Update to update the server.\u0022);\n",
        "runImpersonated": false,
        "stopService": false,
        "ignoreErrors": false,
        "order": 0,
        "icon": "",
        "scriptInputVariables": [],
        "scriptRoles": [],
        "editor": [],
        "identifier": "6f83c50f-fac8-46e1-a16e-1e5f5420aed3"
      }
    },
    {
      "script": {
        "allGames": false,
        "global": false,
        "scriptEngine": "CSharp",
        "operatingSystem": [
          "Windows",
          "Linux"
        ],
        "scriptEvents": [
          "CustomServiceIcon"
        ],
        "name": "Wipe server",
        "description": "Wipe map and player data",
        "code": "using System;\nusing System.IO;\n\nvar Globals = new TCAdmin.Scripting.Engines.Addons.CSharpGameGlobals(); // DO NOT MODIFY THIS LINE\n\n// CustomServiceIcon, stop-service = true (the framework stops the service before this runs).\n// Deletes the Valheim world save folder. Faithful port of the V2 wipe: existence check,\n// recursive delete, wrap failures in a clear exception so the icon action reports an error.\nstring worldFolder = Path.Combine(ThisService.RootDirectory, \u0022worlds\u0022);\n\nif (Directory.Exists(worldFolder))\n{\n    try\n    {\n        Directory.Delete(worldFolder, true);\n        ScriptConsole.WriteLine(\u0022Server has been wiped\u0022);\n    }\n    catch (IOException e)\n    {\n        throw new Exception($\u0022Could not wipe data. Error was: {e.Message}\u0022, e);\n    }\n}\nelse\n{\n    ScriptConsole.WriteLine(\u0022No files to delete\u0022);\n}\n",
        "runImpersonated": false,
        "stopService": true,
        "ignoreErrors": false,
        "order": 0,
        "icon": "",
        "scriptInputVariables": [],
        "scriptRoles": [],
        "editor": [],
        "identifier": "ff427772-75db-4e6b-b9a3-bed3e01133d2"
      }
    },
    {
      "script": {
        "allGames": false,
        "global": false,
        "scriptEngine": "CSharp",
        "operatingSystem": [
          "Windows",
          "Linux"
        ],
        "scriptEvents": [
          "AfterSteamUpdate"
        ],
        "name": "Update Valheim Plus after update",
        "description": "Update Valheim Plus after update",
        "code": "//refAssemblies: TCAdmin.Web.Shared.dll\nusing System;\nusing System.IO;\nusing System.Net.Http;\nusing System.Threading.Tasks;\nusing TCAdmin.SDK.Misc.Compression;\nusing TCAdmin.Web.Shared.Models.Enums;\n\nvar Globals = new TCAdmin.Scripting.Engines.Addons.CSharpGameGlobals(); // DO NOT MODIFY THIS LINE\n\n// DownloadGameFiles event \u2014 runs after the game files are updated. If ValheimPlus is\n// installed, re-download the matching release archive and extract it over the service root.\n//\n// V2 chose the archive by HOST OS (Environment.OSVersion.Platform). That is the exact\n// latent bug the V3 playbook warns about: a Windows Valheim server can run on a Linux host\n// (Wine) and vice versa (WSL), so the archive must follow the GAME\u0027s OS, not the host\u0027s.\nScriptConsole.WriteLine(\u0022Checking if Valheim Plus is installed...\u0022);\n\nstring modZipFile = ThisGame.OperatingSystem == EOperatingSystem.Windows\n    ? \u0022WindowsServer.zip\u0022\n    : \u0022UnixServer.tar.gz\u0022;\n\nstring pluginDll = Path.Combine(ThisService.RootDirectory, \u0022BepInEx\u0022, \u0022plugins\u0022, \u0022ValheimPlus.dll\u0022);\nif (!File.Exists(pluginDll))\n{\n    ScriptConsole.WriteLine(\u0022Valheim Plus not installed.\u0022);\n    return;\n}\n\nstring archivePath = Path.Combine(ThisService.RootDirectory, modZipFile);\nif (File.Exists(archivePath))\n    File.Delete(archivePath);\n\nScriptConsole.WriteLine(\u0022Found Valheim Plus installation... Updating mod.\u0022);\nstring url = \u0022https://github.com/valheimPlus/ValheimPlus/releases/latest/download/\u0022 \u002B modZipFile;\nScriptConsole.WriteLine($\u0022Downloading File {archivePath} from {url}...\\n\\n\u0022);\n\nusing (var httpClient = new HttpClient())\n{\n    httpClient.Timeout = TimeSpan.FromMinutes(10);\n    using var response = await httpClient.GetAsync(url, HttpCompletionOption.ResponseHeadersRead, ThisCancellationToken);\n    response.EnsureSuccessStatusCode();\n    using var httpStream = await response.Content.ReadAsStreamAsync(ThisCancellationToken);\n    using var fileStream = new FileStream(archivePath, FileMode.Create, FileAccess.Write, FileShare.None);\n    await httpStream.CopyToAsync(fileStream, ThisCancellationToken);\n}\n\nif (File.Exists(archivePath))\n{\n    // V2 used TCAdmin.SDK.Misc.CompressionTools().Decompress(zip, root). V3\u0027s CompressionTools\n    // takes the IOperatingSystem (the OperatingSystem global) and the overload that builds its\n    // own VirtualDirectoryRoot handles the extraction target.\n    var compressionTools = new CompressionTools(OperatingSystem)\n    {\n        SetFileOwnerAutomatically = true,\n        ThrowException = true\n    };\n    compressionTools.Decompress(archivePath, ThisService.RootDirectory, ThisCancellationToken);\n    File.Delete(archivePath);\n    ScriptConsole.WriteLine(\u0022Valheim Plus updated.\u0022);\n}\n",
        "runImpersonated": false,
        "stopService": false,
        "ignoreErrors": false,
        "order": 0,
        "icon": "",
        "scriptInputVariables": [],
        "scriptRoles": [],
        "editor": [],
        "identifier": "0be07661-3e37-4cb5-a9bf-224b68323a39"
      }
    },
