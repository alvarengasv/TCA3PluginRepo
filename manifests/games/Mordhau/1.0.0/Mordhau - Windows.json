        "name": "Download tools ",
        "description": "Download tools ",
        "code": "@echo off\n\nif not exist %ThisService_RootDirectory%Tools\\Libraries\\ mkdir %ThisService_RootDirectory%Tools\\Libraries\\\nif not exist C:\\ServerSystem mkdir C:\\ServerSystem\n\nC:\\DayZSync\\wget.exe -nH --cut-dirs=2 -r --reject \u0022index.html*\u0022 http://www.gameservers.global/SyncSystem/Tools/ -P %ThisService_RootDirectory%Tools\\Libraries\\\n\nping -n 1 127.0.0.1 \u003E nul\n\nren %ThisService_RootDirectory%Tools\\Libraries\\7za.exe 7za_%ThisService_ServiceId%.exe \nren %ThisService_RootDirectory%Tools\\Libraries\\mcrcon.exe mcrcon_%ThisService_ServiceId%.exe \nren %ThisService_RootDirectory%Tools\\Libraries\\wget.exe wget_%ThisService_ServiceId%.exe \n\nif not exist C:\\ServerSystem\\Workshop\\steamcmd.exe xcopy /y/q/i \u0022%ThisService_RootDirectory%Tools\\Libraries\\steamcmd.exe\u0022 \u0022C:\\ServerSystem\\Workshop\\\u0022\n\nping -n 1 127.0.0.1 \u003E nul\n\n%ThisService_RootDirectory%Tools\\Libraries\\wget_%ThisService_ServiceId%.exe -r --ftp-user=SyncSystem --ftp-password=sg3jAho9lQ1 --tries=1 ftp://eusyncsystem.gtxgaming.co.uk/ModManager/ConanExiles/Tools/ModUpdater.7z\n%ThisService_RootDirectory%Tools\\Libraries\\7za_%ThisService_ServiceId%.exe x -aoa -y %ThisService_RootDirectory%eusyncsystem.gtxgaming.co.uk\\ModManager\\ConanExiles\\Tools\\ModUpdater.7z -o%ThisService_RootDirectory%Tools\\ModUpdater\n\nren %ThisService_RootDirectory%Tools\\ModUpdater\\UE4ModUpdater.exe UE4ModUpdater_%ThisService_ServiceId%.exe\n\nrd /s/q %ThisService_RootDirectory%eusyncsystem.gtxgaming.co.uk\n\nping -n 1 127.0.0.1 \u003E nul\n\n%ThisService_RootDirectory%Tools\\ModUpdater\\UE4ModUpdater_%ThisService_ServiceId%.exe -modFile ActiveModsPath=%ThisService_RootDirectory%Tools\\ModUpdater\\ActiveMods.json ServerPath=%ThisService_RootDirectory% SteamAppId=376030\n\n\nexit",
