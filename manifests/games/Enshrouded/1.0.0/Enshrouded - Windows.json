    {
      "script": {
        "allGames": false,
        "global": false,
        "scriptEngine": "CSharp",
        "operatingSystem": [
          "Windows",
          "Linux"
        ],
        "scriptEvents": [
          "AfterServiceCreated",
          "AfterServiceReinstalled",
          "BeforeServiceStarted"
        ],
        "name": "Install Wine dependencies (VC\u002B\u002B)",
        "description": "Startup fix",
        "code": "//refAssemblies: TCAdmin.Web.Shared.dll\nusing System;\nusing System.IO;\nusing System.Diagnostics;\nusing System.Threading.Tasks;\n\nvar Globals = new TCAdmin.Scripting.Engines.Addons.CSharpGameGlobals(); // DO NOT MODIFY\n\n// Wine dependency provisioning. The script must be marked Windows (the game\u0027s OS) so the script\n// DB-filter (which keys on the GAME OS) fetches it at all; we then gate on the HOST being Linux so\n// winetricks only runs on the Wine path and is a no-op on native Windows hosts.\n// Bound to AfterServiceCreated / AfterServiceReinstalled (runs inside the create/reinstall task, no\n// start timeout) AND BeforeServiceStarted (safety net). Idempotent via a marker. Installs the VC\u002B\u002B /\n// D3D runtimes the game needs into the wine prefix via winetricks, run as the prefix\u0027s owning user.\n// winetricks creates the prefix (wineboot) if it doesn\u0027t exist yet (create-time); EnsurePrefixAsync\n// at first start then reuses it. The marker is stamped by the shell after winetricks so it survives a\n// cancelled/slow start.\n\nif (!System.OperatingSystem.IsLinux())\n{\n    ScriptConsole.WriteLine(\u0022[wine-deps] Native Windows host \u00E2\u20AC\u201D runtimes installed by the OS installer; skipping winetricks.\u0022);\n    return;\n}\n\nstring root = ThisService.RootDirectory;\nstring prefix = Path.Combine(root, \u0022.wine\u0022);\nstring marker = Path.Combine(prefix, \u0022.tcadmin-winedeps\u0022);\n\nif (File.Exists(marker))\n{\n    ScriptConsole.WriteLine(\u0022[wine-deps] Runtimes already installed in the wine prefix.\u0022);\n    return;\n}\n\nScriptConsole.WriteLine(\u0022[wine-deps] Installing VC\u002B\u002B/D3D runtimes into the wine prefix via winetricks (can take a few minutes)...\u0022);\n\n// Owner is taken from the service ROOT (always present and chowned to the service user by the create\u0027s\n// file-permission pass) \u00E2\u20AC\u201D the .wine prefix may not exist yet at create-time. winetricks creates it.\nstring b = string.Join(\u0022 \u0022,\n    \u0022set -e;\u0022,\n    $\u0022ROOT=\u0027{root}\u0027;\u0022,\n    \u0022PREFIX=\\\u0022$ROOT/.wine\\\u0022;\u0022,\n    \u0022MARKER=\\\u0022$PREFIX/.tcadmin-winedeps\\\u0022;\u0022,\n    \u0022OWNER=$(stat -c \u0027%U\u0027 \\\u0022$ROOT\\\u0022);\u0022,\n    \u0022echo \\\u0022[wine-deps] service user: $OWNER\\\u0022;\u0022,\n    \u0022RT=\\\u0022$ROOT/.tca/xdg-runtime\\\u0022; mkdir -p \\\u0022$RT\\\u0022; chmod 700 \\\u0022$RT\\\u0022; chown \\\u0022$OWNER\\\u0022 \\\u0022$RT\\\u0022;\u0022,\n    \u0022runuser -u \\\u0022$OWNER\\\u0022 -- env WINEPREFIX=\\\u0022$PREFIX\\\u0022 HOME=\\\u0022$ROOT\\\u0022 XDG_RUNTIME_DIR=\\\u0022$RT\\\u0022 WINEDEBUG=-all WINEDLLOVERRIDES=\u0027mscoree=;mshtml=\u0027 xvfb-run -a winetricks -q vcrun2019 d3dcompiler_47;\u0022,\n    \u0022touch \\\u0022$MARKER\\\u0022; chown \\\u0022$OWNER\\\u0022 \\\u0022$MARKER\\\u0022;\u0022,\n    \u0022echo \u0027[wine-deps] winetricks finished\u0027;\u0022);\n\nvar psi = new ProcessStartInfo\n{\n    FileName = \u0022/bin/bash\u0022,\n    UseShellExecute = false,\n    RedirectStandardOutput = true,\n    RedirectStandardError = true,\n};\npsi.ArgumentList.Add(\u0022-c\u0022);\npsi.ArgumentList.Add(b);\n\nusing (var p = Process.Start(psi))\n{\n    string outText = await p.StandardOutput.ReadToEndAsync();\n    string errText = await p.StandardError.ReadToEndAsync();\n    await p.WaitForExitAsync();\n    if (!string.IsNullOrWhiteSpace(outText))\n        ScriptConsole.WriteLine(outText.Length \u003E 2500 ? outText.Substring(outText.Length - 2500) : outText);\n    if (!string.IsNullOrWhiteSpace(errText))\n        ScriptConsole.WriteLine(\u0022[wine-deps stderr] \u0022 \u002B (errText.Length \u003E 1200 ? errText.Substring(errText.Length - 1200) : errText));\n    ScriptConsole.WriteLine($\u0022[wine-deps] winetricks exit code: {p.ExitCode}\u0022);\n}\n",
        "runImpersonated": false,
        "stopService": false,
        "ignoreErrors": true,
